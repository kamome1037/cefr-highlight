{
  "name": "cefr-highlight",
  "displayName": "CEFR Highlight",
  "description": "Highlight English words by CEFR level (A1–C2) with semantic tokens and hover definitions",
  "version": "0.3.0",
  "publisher": "kamome",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages", "Education"],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cefr",
        "aliases": ["CEFR Text", "cefr"],
        "extensions": [".cefr"],
        "configuration": "./language-configuration.json"
      }
    ],
    "semanticTokenTypes": [
      { "id": "cefrA1", "superType": "variable", "description": "CEFR A1 — Beginner" },
      { "id": "cefrA2", "superType": "variable", "description": "CEFR A2 — Elementary" },
      { "id": "cefrB1", "superType": "variable", "description": "CEFR B1 — Intermediate" },
      { "id": "cefrB2", "superType": "variable", "description": "CEFR B2 — Upper-intermediate" },
      { "id": "cefrC1", "superType": "variable", "description": "CEFR C1 — Advanced" },
      { "id": "cefrC2", "superType": "variable", "description": "CEFR C2 — Proficiency" }
    ],
    "semanticTokenModifiers": [
      { "id": "phrase", "description": "Multi-word CEFR phrase" }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "cefrA1": ["markup.other.cefrA1"],
          "cefrA2": ["markup.other.cefrA2"],
          "cefrB1": ["markup.other.cefrB1"],
          "cefrB2": ["markup.other.cefrB2"],
          "cefrC1": ["markup.other.cefrC1"],
          "cefrC2": ["markup.other.cefrC2"]
        }
      }
    ],
    "configuration": {
      "title": "CEFR Highlight",
      "properties": {
        "cefrHighlight.minimumLevel": {
          "type": "string",
          "default": "B2",
          "enum": ["A1", "A2", "B1", "B2", "C1", "C2"],
          "enumDescriptions": [
            "Show all levels (A1 and above)",
            "Show A2 and above",
            "Show B1 and above",
            "Show B2 and above",
            "Show C1 and above",
            "Show C2 only"
          ],
          "description": "Only highlight words at or above this CEFR level."
        },
        "cefrHighlight.colors.A1": {
          "type": "string",
          "default": "#BDBDBD",
          "description": "Foreground color for A1 (Beginner) words."
        },
        "cefrHighlight.colors.A2": {
          "type": "string",
          "default": "#43A047",
          "description": "Foreground color for A2 (Elementary) words."
        },
        "cefrHighlight.colors.B1": {
          "type": "string",
          "default": "#1E88E5",
          "description": "Foreground color for B1 (Intermediate) words."
        },
        "cefrHighlight.colors.B2": {
          "type": "string",
          "default": "#8E24AA",
          "description": "Foreground color for B2 (Upper-intermediate) words."
        },
        "cefrHighlight.colors.C1": {
          "type": "string",
          "default": "#CDDC39",
          "description": "Foreground color for C1 (Advanced) words."
        },
        "cefrHighlight.colors.C2": {
          "type": "string",
          "default": "#FB8C00",
          "description": "Foreground color for C2 (Proficiency) words."
        },
        "cefrHighlight.phraseBackground": {
          "type": "string",
          "default": "rgba(255, 235, 59, 0.15)",
          "description": "Background color for multi-word CEFR phrases."
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[cefr]": {
        "editor.semanticHighlighting.enabled": true
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "cefrA1": { "foreground": "#BDBDBD", "fontStyle": "" },
          "cefrA2": { "foreground": "#43A047", "fontStyle": "" },
          "cefrB1": { "foreground": "#1E88E5", "fontStyle": "" },
          "cefrB2": { "foreground": "#8E24AA", "fontStyle": "" },
          "cefrC1": { "foreground": "#CDDC39", "fontStyle": "" },
          "cefrC2": { "foreground": "#FB8C00", "fontStyle": "bold" }
        }
      }
    }
  },
  "scripts": {
    "compile": "cd client && npm run compile",
    "watch": "cd client && npm run watch",
    "build:server": "cd server && cargo build --release"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "typescript": "^5.3.0"
  }
}
